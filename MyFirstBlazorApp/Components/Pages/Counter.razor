@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<Welcome Name="2Hamza"/>

<Welcome Name="1Hamza"/>

<h1>--------------------------------</h1>
<Welcome> </Welcome>

<Welcome Name="Hamza"></Welcome>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

